// Brought to u by MidManStudio

@CONFIG(
  version    -> "1.0.0"
  author     -> "MidManStudio"
  features   -> "data"
  debug_mode -> "off"
)

@QUICKFUNCS(
  ~target<object>(name, path) { return { name = name, path = path } }
)

@DATA(
  target_root = "."

  overrides::
    target("wrangler.jsonc", "wrangler.jsonc")
    target("package.json",   "package.json")
    target("tsconfig.json",  "tsconfig.json")
    target("schema.sql",     "schema.sql")
    target("SETUP.md",       "SETUP.md")
)
