@CONFIG(
  version    -> "1.0.0"
  author     -> "MidManStudio"
  
  debug_mode -> "off"
)

@QUICKFUNCS(
  ~target<object>(name, path) { return { name = name, path = path } }
)

@DATA(
  target_root = "src"

  ignore::
    "README.md"

  overrides::
    target("Hero.svelte", "src/lib/components/Hero.svelte")
)
