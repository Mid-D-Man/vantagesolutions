name: Deploy Contacts Worker

on:
  push:
    branches: [main]
    paths:
      - 'contacts/**'
  workflow_dispatch:

jobs:
  deploy:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: contacts
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Node
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Install dependencies
        run: npm install

      # Safe to re-run: if the database already exists this just finds its id.
      # Only creates a new one the first time this ever runs.
      - name: Ensure D1 database exists
        env:
          CLOUDFLARE_API_TOKEN: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          CLOUDFLARE_ACCOUNT_ID: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
        run: |
          set -e
          DB_NAME="vantage-contacts"

          LIST_JSON=$(npx wrangler d1 list --json)
          echo "$LIST_JSON"

          DB_ID=$(node -e "
            const list = JSON.parse(process.argv[1]);
            const match = list.find(d => d.name === process.argv[2]);
            console.log(match ? (match.uuid || match.database_id || '') : '');
          " "$LIST_JSON" "$DB_NAME")

          if [ -z "$DB_ID" ]; then
            echo "No existing $DB_NAME database - creating it..."
            CREATE_JSON=$(npx wrangler d1 create "$DB_NAME" --json)
            echo "$CREATE_JSON"
            DB_ID=$(node -e "
              const r = JSON.parse(process.argv[1]);
              const row = Array.isArray(r) ? r[0] : r;
              console.log(row.uuid || row.database_id || '');
            " "$CREATE_JSON")
          else
            echo "Found existing $DB_NAME database."
          fi

          if [ -z "$DB_ID" ]; then
            echo "::error::Could not determine the D1 database id from wrangler output above - the JSON shape may differ from what this script expects."
            exit 1
          fi

          echo "Using database_id: $DB_ID"
          sed -i "s/REPLACE_WITH_YOUR_D1_DATABASE_ID/$DB_ID/" wrangler.jsonc

      # schema.sql uses CREATE TABLE/INDEX IF NOT EXISTS throughout, so this is
      # always safe to re-run - it never touches existing data.
      - name: Apply schema
        env:
          CLOUDFLARE_API_TOKEN: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          CLOUDFLARE_ACCOUNT_ID: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
        run: npx wrangler d1 execute vantage-contacts --remote --file=./schema.sql

      - name: Deploy Worker
        env:
          CLOUDFLARE_API_TOKEN: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          CLOUDFLARE_ACCOUNT_ID: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
        run: npx wrangler deploy
